usage() {
  cat <<EOF2
Usage:
  ${SCRIPT_NAME} --provider <provider> --region <region> --plan <plan> --price <price> [options]

Required:
  --provider         Provider display name
  --region           Region display name
  --plan             Plan display name
  --price            Monthly price in USD

Optional:
  --measurement-epoch Measurement epoch label (default: ${MEASUREMENT_EPOCH})
  --iperf-parallel   iperf3 parallel streams (default: ${IPERF_PARALLEL})
  --iperf-duration   iperf3 duration seconds (default: ${IPERF_DURATION})
  -h, --help         Show help
EOF2
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

log() {
  echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] $*"
}

slugify() {
  local s="${1,,}"
  s="$(echo "$s" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  printf '%s' "$s"
}

append_status_note() {
  STATUS_NOTES+=("$1")
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

detect_os_name() {
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "${PRETTY_NAME:-${NAME:-unknown}}"
  else
    uname -s
  fi
}

detect_virtualization() {
  if command -v systemd-detect-virt >/dev/null 2>&1; then
    systemd-detect-virt 2>/dev/null || echo "none"
    return 0
  fi
  if grep -qi hypervisor /proc/cpuinfo 2>/dev/null; then
    echo "virtualized"
  else
    echo "unknown"
  fi
}

to_float_gb() {
  python3 - <<'PY' "$1"
import sys
kb = float(sys.argv[1])
print(f"{kb / 1024 / 1024:.2f}")
PY
}

compute_fio_size() {
  python3 - <<'PY' "$1"
import sys
ram = float(sys.argv[1])
if ram <= 8:
    print("1G")
elif ram <= 16:
    print("2G")
else:
    print("4G")
PY
}

ns_to_ms_expr() {
  python3 - <<'PY' "$1"
import sys
v = sys.argv[1]
if v in ("", "None", "null"):
    print("null")
else:
    print(float(v) / 1_000_000)
PY
}

bps_to_gbps_expr() {
  python3 - <<'PY' "$1"
import sys
v = sys.argv[1]
if v in ("", "None", "null"):
    print("null")
else:
    print(float(v) / 1_000_000_000)
PY
}

json_or_null() {
  local v="${1:-}"
  if [[ -z "$v" ]]; then
    printf 'null'
  else
    printf '%s' "$v"
  fi
}

ensure_dir() {
  mkdir -p "$1"
}

ensure_base_dir_writable() {
  ensure_dir "$BASE_DIR"
  [[ -w "$BASE_DIR" ]] || die "BASE_DIR is not writable: $BASE_DIR"
}

validate_price() {
  python3 - <<'PY' "$PRICE"
import sys
try:
    value = float(sys.argv[1])
except Exception:
    raise SystemExit(1)
if value < 0:
    raise SystemExit(1)
PY
}

timestamp_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

date_utc() {
  date -u +"%Y-%m-%d"
}

build_run_id() {
  printf '%s-%s-%s-%s-%s' "$PROVIDER_SLUG" "$REGION_SLUG" "$PLAN_SLUG" "$RUN_DATE" "$RUN_SEQ"
}

pick_next_sequence() {
  local prefix="${PROVIDER_SLUG}-${REGION_SLUG}-${PLAN_SLUG}-${RUN_DATE}-"
  local existing
  existing="$(find "${BASE_DIR}/${PROVIDER_SLUG}" -maxdepth 1 -mindepth 1 -type d -name "${prefix}*" 2>/dev/null | sed -E "s|.*/${prefix}([0-9]+)$|\1|" | sort -n | tail -n 1 || true)"
  if [[ -z "${existing:-}" ]]; then
    echo "001"
  else
    printf '%03d' $((10#$existing + 1))
  fi
}

update_global_status() {
  local statuses=(
    "$CPU_STATUS"
    "$STORAGE_STATUS"
    "$NET_US_OUT_STATUS"
    "$NET_US_IN_STATUS"
    "$NET_EU_OUT_STATUS"
    "$NET_EU_IN_STATUS"
    "$NET_ASIA_OUT_STATUS"
    "$NET_ASIA_IN_STATUS"
  )

  GLOBAL_STATUS="ok"

  for s in "${statuses[@]}"; do
    case "$s" in
      failed_busy|failed_timeout|failed_connection|failed_incomplete|failed_error)
        if [[ "$GLOBAL_STATUS" != "error" ]]; then
          GLOBAL_STATUS="partial"
        fi
        ;;
      failed|parse_error|missing)
        GLOBAL_STATUS="error"
        return 0
        ;;
      ok|not_run)
        ;;
      *)
        GLOBAL_STATUS="error"
        return 0
        ;;
    esac
  done
}

cleanup_on_error() {
  local exit_code=$?
  FINISHED_AT_UTC="$(timestamp_utc)"
  GLOBAL_STATUS="error"
  append_status_note "runner_exit_code=${exit_code}"
  log "Aborting with exit code ${exit_code}"
  if [[ -n "${RUN_DIR:-}" ]]; then
    write_run_md || true
    write_run_json || true
  fi
  exit "$exit_code"
}
trap cleanup_on_error ERR

parse_args() {
  RUNNER_ARGS=("$@")
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider)
        PROVIDER="${2:-}"
        shift 2
        ;;
      --region)
        REGION="${2:-}"
        shift 2
        ;;
      --plan)
        PLAN="${2:-}"
        shift 2
        ;;
      --price)
        PRICE="${2:-}"
        shift 2
        ;;
      --iperf-parallel)
        IPERF_PARALLEL="${2:-}"
        shift 2
        ;;
      --iperf-duration)
        IPERF_DURATION="${2:-}"
        shift 2
        ;;
      --measurement-epoch)
        MEASUREMENT_EPOCH="${2:-}"
        EPOCH="${MEASUREMENT_EPOCH}"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done

  [[ -n "$PROVIDER" ]] || die "--provider is required"
  [[ -n "$REGION" ]] || die "--region is required"
  [[ -n "$PLAN" ]] || die "--plan is required"
  [[ -n "$PRICE" ]] || die "--price is required"

  [[ "$IPERF_PARALLEL" =~ ^[0-9]+$ ]] || die "--iperf-parallel must be an integer"
  [[ "$IPERF_DURATION" =~ ^[0-9]+$ ]] || die "--iperf-duration must be an integer"
  validate_price || die "--price must be a non-negative number"
}

check_dependencies() {
  require_cmd bash
  require_cmd python3
  require_cmd awk
  require_cmd sed
  require_cmd grep
