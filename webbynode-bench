usage() {
  cat <<EOF2
Usage:
  ${SCRIPT_NAME} --provider <provider> --region <region> --plan <plan> --price <price> [options]

Required:
  --provider         Provider display name
  --region           Region display name
  --plan             Plan display name
  --price            Monthly price in USD

Optional:
  --measurement-epoch Measurement epoch label (default: ${MEASUREMENT_EPOCH})
  --agent-sim-enabled 1/0 to enable agent simulation run (default: ${AGENT_SIM_ENABLED})
  --agent-sim-duration Duration in seconds for agent simulation run (default: ${AGENT_SIM_DURATION})
  --iperf-parallel   iperf3 parallel streams (default: ${IPERF_PARALLEL})
  --iperf-duration   iperf3 duration seconds (default: ${IPERF_DURATION})
  -h, --help         Show help
EOF2
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

log() {
  echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] $*"
}

slugify() {
  local s="${1,,}"
  s="$(echo "$s" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  printf '%s' "$s"
}

append_status_note() {
  STATUS_NOTES+=("$1")
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

detect_os_name() {
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "${PRETTY_NAME:-${NAME:-unknown}}"
  else
    uname -s
  fi
}

detect_virtualization() {
  if command -v systemd-detect-virt >/dev/null 2>&1; then
    systemd-detect-virt 2>/dev/null || echo "none"
    return 0
  fi
  if grep -qi hypervisor /proc/cpuinfo 2>/dev/null; then
    echo "virtualized"
  else
    echo "unknown"
  fi
}

to_float_gb() {
  python3 - <<'PY' "$1"
import sys
kb = float(sys.argv[1])
print(f"{kb / 1024 / 1024:.2f}")
PY
}

compute_fio_size() {
  python3 - <<'PY' "$1"
import sys
ram = float(sys.argv[1])
if ram <= 8:
    print("1G")
elif ram <= 16:
    print("2G")
else:
    print("4G")
PY
}

