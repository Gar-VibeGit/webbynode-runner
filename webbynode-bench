validate_run_json() {
  log "Validating run.json"
  python3 - "$RUN_JSON" "$RUN_DIR" "$RUN_ID" <<'PY'
import json, os, re, sys
run_json, run_dir, expected_run_id = sys.argv[1:]
with open(run_json, 'r', encoding='utf-8') as f:
    data = json.load(f)
required_top = [
    'schema_version', 'epoch', 'methodology_version', 'run_id', 'status',
    'provider', 'region', 'plan', 'pricing', 'environment', 'commands', 'results', 'artifacts', 'timestamps'
]
missing = [k for k in required_top if k not in data]
if missing:
    raise SystemExit(f"Missing required top-level keys: {missing}")
if data['run_id'] != expected_run_id:
    raise SystemExit('run_id mismatch')
if not re.match(r'^[a-z0-9-]+-[a-z0-9-]+-[a-z0-9-]+-\d{4}-\d{2}-\d{2}-\d{3}$', data['run_id']):
    raise SystemExit('run_id format invalid')
for name in [
    'run.log', 'raw.sysbench.log', 'raw.fio.log',
    'raw.iperf-us-east-outbound.log', 'raw.iperf-us-east-inbound.log',
    'raw.iperf-eu-west-outbound.log', 'raw.iperf-eu-west-inbound.log',
    'raw.iperf-asia-outbound.log', 'raw.iperf-asia-inbound.log',
    'run.md',
]:
    if not os.path.exists(os.path.join(run_dir, name)):
        raise SystemExit(f'Missing artifact: {name}')
for endpoint in ['us_east', 'eu_west', 'asia']:
    if endpoint not in data['results']['network']:
        raise SystemExit(f'Missing network endpoint: {endpoint}')
print('run.json validation passed')
PY
}

main() {
  parse_args "$@"
  check_dependencies
  ensure_base_dir_writable
  init_run
  detect_environment
  run_cpu
  run_storage
  run_network
  run_agent_sim
  FINISHED_AT_UTC="$(timestamp_utc)"
  write_run_md
  write_run_json
  validate_run_json
  log "Completed"
  log "Global status: ${GLOBAL_STATUS}"
  log "Artifacts written to ${RUN_DIR}"
}

