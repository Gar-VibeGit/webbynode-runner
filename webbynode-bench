validate_run_json() {
  python3 - <<'PY' "$RUN_JSON" "$RUN_DIR" "$RUN_ID"
import json, os, re, sys

run_json_path, run_dir, expected_run_id = sys.argv[1:]

with open(run_json_path, "r", encoding="utf-8") as f:
    data = json.load(f)

required = ["version", "run_id", "metadata", "environment", "commands", "benchmarks", "artifacts"]
missing = [k for k in required if k not in data]
if missing:
    raise SystemExit(f"Missing keys: {missing}")

if data["version"] != "1.0":
    raise SystemExit("version must equal 1.0")

if data["run_id"] != expected_run_id:
    raise SystemExit("run_id mismatch")

if not re.match(r"^[a-z0-9-]+-[a-z0-9-]+-[a-z0-9-]+-\d{4}-\d{2}-\d{2}-\d{3}$", data["run_id"]):
    raise SystemExit("run_id format invalid")

for name in [
    "run.log",
    "raw.sysbench.log",
    "raw.fio.log",
    "raw.iperf-us-east-outbound.log",
    "raw.iperf-us-east-inbound.log",
    "raw.iperf-eu-west-outbound.log",
    "raw.iperf-eu-west-inbound.log",
    "run.md",
]:
    if not os.path.exists(os.path.join(run_dir, name)):
        raise SystemExit(f"Missing artifact: {name}")

print("run.json validation passed")
PY
}

main() {
  parse_args "$@"
  validate_inputs
  check_dependencies
  init_run
  detect_environment
  run_cpu
  run_storage
  run_network
  write_run_md
  write_run_json
  validate_run_json
  log "Benchmark complete: $RUN_ID"
  log "Artifacts written to $RUN_DIR"
}

main "$@"