init_run() {
  PROVIDER_SLUG="$(slugify "$PROVIDER")"
  REGION_SLUG="$(slugify "$REGION")"
  PLAN_SLUG="$(slugify "$PLAN")"
  RUN_DATE="$(date_utc)"

  ensure_dir "${BASE_DIR}/${PROVIDER_SLUG}"
  RUN_SEQ="$(pick_next_sequence)"
  RUN_ID="$(build_run_id)"
  RUN_DIR="${BASE_DIR}/${PROVIDER_SLUG}/${RUN_ID}"
  ensure_dir "$RUN_DIR"

  RUN_LOG="${RUN_DIR}/run.log"
  RAW_SYSBENCH_LOG="${RUN_DIR}/raw.sysbench.log"
  RAW_FIO_LOG="${RUN_DIR}/raw.fio.log"
  RAW_IPERF_US_OUT_LOG="${RUN_DIR}/raw.iperf-us-east-outbound.log"
  RAW_IPERF_US_IN_LOG="${RUN_DIR}/raw.iperf-us-east-inbound.log"
  RAW_IPERF_EU_OUT_LOG="${RUN_DIR}/raw.iperf-eu-west-outbound.log"
  RAW_IPERF_EU_IN_LOG="${RUN_DIR}/raw.iperf-eu-west-inbound.log"
  RAW_IPERF_ASIA_OUT_LOG="${RUN_DIR}/raw.iperf-asia-outbound.log"
  RAW_IPERF_ASIA_IN_LOG="${RUN_DIR}/raw.iperf-asia-inbound.log"
  RUN_JSON="${RUN_DIR}/run.json"
  RUN_MD="${RUN_DIR}/run.md"

  STARTED_AT_UTC="$(timestamp_utc)"
  exec > >(tee -a "$RUN_LOG") 2>&1

  log "Starting benchmark ${RUN_ID}"
  log "RUN_DIR=${RUN_DIR}"
}

detect_environment() {
  CPU_MODEL="$(lscpu | awk -F: '/Model name/ {gsub(/^[ \t]+/, "", $2); print $2; exit}')"
  [[ -n "$CPU_MODEL" ]] || CPU_MODEL="$(awk -F: '/model name/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' /proc/cpuinfo 2>/dev/null || true)"
  [[ -n "$CPU_MODEL" ]] || CPU_MODEL="unknown"

  VCPU_COUNT="$(nproc 2>/dev/null || true)"
  [[ -n "$VCPU_COUNT" ]] || VCPU_COUNT="$(grep -c '^processor' /proc/cpuinfo 2>/dev/null || echo "1")"

  local mem_kb
  mem_kb="$(awk '/MemTotal/ {print $2; exit}' /proc/meminfo)"
  RAM_GB="$(to_float_gb "$mem_kb")"

  OS_NAME="$(detect_os_name)"
  KERNEL_VERSION="$(uname -r)"
  ARCH="$(uname -m)"
  HOSTNAME_FQDN="$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo "unknown")"
  VIRT_TYPE="$(detect_virtualization)"
  FIO_SIZE="$(compute_fio_size "$RAM_GB")"

  if [[ -z "$SYSBENCH_THREADS_OVERRIDE" ]]; then
    SYSBENCH_THREADS_OVERRIDE="$VCPU_COUNT"
  fi
}

run_cpu() {
  log "Running CPU benchmark"
  local cmd=(
    sysbench cpu
    --threads="${SYSBENCH_THREADS_OVERRIDE}"
    --time="${SYSBENCH_TIME}"
    --cpu-max-prime="${SYSBENCH_CPU_MAX_PRIME}"
    run
  )

  printf '%q ' "${cmd[@]}" | sed 's/ $/\n/' > "${RUN_DIR}/cmd.sysbench.txt"

  set +e
  "${cmd[@]}" | tee "$RAW_SYSBENCH_LOG"
  local rc=$?
  set -e

  if [[ $rc -eq 0 && -s "$RAW_SYSBENCH_LOG" ]]; then
    CPU_STATUS="ok"
  else
    CPU_STATUS="failed"
    append_status_note "cpu=failed"
    return 0
  fi

  CPU_EVENTS_PER_SECOND="$(awk '/events per second:/ {print $4; exit}' "$RAW_SYSBENCH_LOG")"
  CPU_LAT_AVG="$(awk '/avg:/ {print $2; exit}' "$RAW_SYSBENCH_LOG")"
  CPU_LAT_P95="$(awk '/95th percentile:/ {print $3; exit}' "$RAW_SYSBENCH_LOG")"
  CPU_LAT_P99=""
}

run_storage() {
  log "Running storage benchmark"

  local fio_target="${RUN_DIR}/${FIO_FILENAME}"
  local cmd=(
    fio
    --name=webbynode-storage
    --filename="${fio_target}"
    --size="${FIO_SIZE}"
    --rw="${FIO_RW}"
    --rwmixread="${FIO_RWMIXREAD}"
    --bs="${FIO_BS}"
    --ioengine=libaio
    --direct=1
    --iodepth="${FIO_IODEPTH}"
    --numjobs="${FIO_NUMJOBS}"
    --time_based=1
    --runtime="${FIO_RUNTIME}"
    --group_reporting=1
    --output-format=json
  )

  printf '%q ' "${cmd[@]}" | sed 's/ $/\n/' > "${RUN_DIR}/cmd.fio.txt"

  set +e
  "${cmd[@]}" | tee "$RAW_FIO_LOG"
  local rc=$?
  set -e

  rm -f "${fio_target}" 2>/dev/null || true

  if [[ $rc -ne 0 || ! -s "$RAW_FIO_LOG" ]]; then
    STORAGE_STATUS="failed"
    FIO_PARSE_STATUS="missing"
    append_status_note "storage=failed"
    return 0
  fi

  local parsed
  parsed="$(python3 - "$RAW_FIO_LOG" <<'PY'
import json, sys
path = sys.argv[1]
try:
    with open(path, 'r', encoding='utf-8') as f:
        j = json.load(f)
    job = j['jobs'][0]
    fio_version = j.get('fio version', '')
    read_iops = job['read'].get('iops')
    write_iops = job['write'].get('iops')
    rp95 = job['read'].get('clat_ns', {}).get('percentile', {}).get('95.000000')
    rp99 = job['read'].get('clat_ns', {}).get('percentile', {}).get('99.000000')
    wp95 = job['write'].get('clat_ns', {}).get('percentile', {}).get('95.000000')
    wp99 = job['write'].get('clat_ns', {}).get('percentile', {}).get('99.000000')
    vals = [read_iops, write_iops, fio_version, rp95, rp99, wp95, wp99]
    print("\t".join("" if v is None else str(v) for v in vals))
except Exception:
    print("PARSE_ERROR")
PY
)"

  if [[ "$parsed" == "PARSE_ERROR" || -z "$parsed" ]]; then
    STORAGE_STATUS="parse_error"
    FIO_PARSE_STATUS="parse_error"
    append_status_note "storage=parse_error"
    return 0
  fi

  IFS=$'\t' read -r FIO_READ_IOPS FIO_WRITE_IOPS FIO_VERSION FIO_READ_P95 FIO_READ_P99 FIO_WRITE_P95 FIO_WRITE_P99 <<< "$parsed"
  STORAGE_STATUS="ok"
  FIO_PARSE_STATUS="ok"
}

parse_iperf_json() {
  local path="$1"
  python3 - "$path" <<'PY'
import json, sys
path = sys.argv[1]
try:
    with open(path, 'r', encoding='utf-8') as f:
        j = json.load(f)
    end = j.get("end", {})
    connected = j.get("start", {}).get("connected", [])
    remote_host = connected[0].get("remote_host") if connected else ""
    sum_sent = end.get("sum_sent", {})
    sum_received = end.get("sum_received", {})
    sent_bps = sum_sent.get("bits_per_second")
    recv_bps = sum_received.get("bits_per_second")
    if "error" in j:
        print("ERROR	{}	{}	{}	{}".format(j.get("error", ""), remote_host, "" if sent_bps is None else sent_bps, "" if recv_bps is None else recv_bps))
    elif sent_bps is None or recv_bps is None:
        print("PARSE_ERROR")
    else:
        print("OK	{}	{}	{}".format(remote_host, sent_bps, recv_bps))
except Exception:
    print("PARSE_ERROR")
PY
}

classify_iperf_error_reason() {
  local outfile="$1"

  if grep -qi "server is busy" "$outfile" || grep -qi "the server is busy" "$outfile"; then
    echo "failed_busy"
    return 0
  fi

  if grep -qi '"error"' "$outfile"; then
    if grep -qi "timed out" "$outfile" || grep -qi "timeout" "$outfile"; then
      echo "failed_timeout"
      return 0
    fi

    if grep -qi "control socket has closed unexpectedly" "$outfile"; then
      echo "failed_connection"
      return 0
    fi

    if grep -qi "unable to connect" "$outfile" || grep -qi "connection refused" "$outfile" || grep -qi "connection reset" "$outfile"; then
      echo "failed_connection"
      return 0
    fi

    echo "failed_error"
    return 0
  fi

  if [[ -s "$outfile" ]]; then
    echo "failed_incomplete"
  else
    echo "missing"
  fi
}

iperf_result_has_error_json() {
  local outfile="$1"
  grep -qi '"error"' "$outfile"
}

run_iperf_with_retry() {
  local endpoint_host="$1"
  local outfile="$2"
  local reverse_flag="${3:-}"
  local status_var="$4"
  local retries_var="$5"
  local label="$6"
  local attempt=1
  local rc=0
  local classified=""

  while (( attempt <= IPERF_RETRIES_MAX )); do
    printf '%q ' iperf3 -c "$endpoint_host" -p "$IPERF_PORT" -P "$IPERF_PARALLEL" -t "$IPERF_DURATION" ${reverse_flag:+-R} -J | sed 's/ $/
/' > "${outfile%.log}.cmd.txt"

    set +e
    if [[ "$reverse_flag" == "reverse" ]]; then
      iperf3 -c "$endpoint_host" -p "$IPERF_PORT" -P "$IPERF_PARALLEL" -t "$IPERF_DURATION" -R -J > "$outfile" 2>&1
    else
      iperf3 -c "$endpoint_host" -p "$IPERF_PORT" -P "$IPERF_PARALLEL" -t "$IPERF_DURATION" -J > "$outfile" 2>&1
    fi
    rc=$?
    set -e

    printf -v "$retries_var" '%s' "$((attempt - 1))"

    local parsed
    parsed="$(parse_iperf_json "$outfile")"

    if [[ "$rc" == "0" ]] && [[ "$parsed" == OK$'	'* ]] && ! iperf_result_has_error_json "$outfile"; then
      printf -v "$status_var" '%s' "ok"
      return 0
    fi

    classified="$(classify_iperf_error_reason "$outfile")"

    if [[ "$classified" == "failed_busy" ]]; then
      if (( attempt < IPERF_RETRIES_MAX )); then
        append_status_note "${label}=busy_retry_${attempt}"
        sleep "$IPERF_RETRY_SLEEP"
        ((attempt++))
        continue
      else
        printf -v "$status_var" '%s' "failed_busy"
        append_status_note "${label}=failed_busy"
        return 0
      fi
    fi

    printf -v "$status_var" '%s' "$classified"
    append_status_note "${label}=${classified}_rc_${rc}"
    return 0
  done

  printf -v "$status_var" '%s' "failed_error"
  append_status_note "${label}=failed_error_fell_through"
  return 0
}

capture_iperf_metrics() {
  local path="$1"
  local remote_var="$2"
  local sent_var="$3"
  local recv_var="$4"
  local parsed

  parsed="$(parse_iperf_json "$path")"
  if [[ "$parsed" == OK$'	'* ]]; then
    local _tag remote sent recv
    IFS=$'	' read -r _tag remote sent recv <<< "$parsed"
    printf -v "$remote_var" '%s' "$remote"
    printf -v "$sent_var" '%s' "$sent"
    printf -v "$recv_var" '%s' "$recv"
  elif [[ "$parsed" == ERROR$'	'* ]]; then
    local _tag errmsg remote sent recv
    IFS=$'	' read -r _tag errmsg remote sent recv <<< "$parsed"
    printf -v "$remote_var" '%s' "$remote"
    printf -v "$sent_var" '%s' "$sent"
    printf -v "$recv_var" '%s' "$recv"
  else
    printf -v "$remote_var" '%s' ""
    printf -v "$sent_var" '%s' ""
    printf -v "$recv_var" '%s' ""
  fi
}

run_network() {
  log "Running US outbound network benchmark"
  run_iperf_with_retry "$US_ENDPOINT" "$RAW_IPERF_US_OUT_LOG" "" NET_US_OUT_STATUS NET_US_OUT_RETRIES_USED "us_outbound" || true
  capture_iperf_metrics "$RAW_IPERF_US_OUT_LOG" US_OUT_REMOTE_HOST US_OUT_SENT_BPS US_OUT_RECEIVED_BPS

  log "Running US inbound network benchmark"
  run_iperf_with_retry "$US_ENDPOINT" "$RAW_IPERF_US_IN_LOG" reverse NET_US_IN_STATUS NET_US_IN_RETRIES_USED "us_inbound" || true
  capture_iperf_metrics "$RAW_IPERF_US_IN_LOG" US_IN_REMOTE_HOST US_IN_SENT_BPS US_IN_RECEIVED_BPS

  log "Running EU outbound network benchmark"
  run_iperf_with_retry "$EU_ENDPOINT" "$RAW_IPERF_EU_OUT_LOG" "" NET_EU_OUT_STATUS NET_EU_OUT_RETRIES_USED "eu_outbound" || true
  capture_iperf_metrics "$RAW_IPERF_EU_OUT_LOG" EU_OUT_REMOTE_HOST EU_OUT_SENT_BPS EU_OUT_RECEIVED_BPS

  log "Running EU inbound network benchmark"
  run_iperf_with_retry "$EU_ENDPOINT" "$RAW_IPERF_EU_IN_LOG" reverse NET_EU_IN_STATUS NET_EU_IN_RETRIES_USED "eu_inbound" || true
  capture_iperf_metrics "$RAW_IPERF_EU_IN_LOG" EU_IN_REMOTE_HOST EU_IN_SENT_BPS EU_IN_RECEIVED_BPS

  log "Running Asia outbound network benchmark"
  run_iperf_with_retry "$ASIA_ENDPOINT" "$RAW_IPERF_ASIA_OUT_LOG" "" NET_ASIA_OUT_STATUS NET_ASIA_OUT_RETRIES_USED "asia_outbound" || true
