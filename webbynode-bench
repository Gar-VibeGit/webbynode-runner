build_run_id() {
  printf '%s-%s-%s-%s-%s' "$PROVIDER_SLUG" "$REGION_SLUG" "$PLAN_SLUG" "$RUN_DATE" "$RUN_SEQ"
}

pick_next_sequence() {
  local prefix="${PROVIDER_SLUG}-${REGION_SLUG}-${PLAN_SLUG}-${RUN_DATE}-"
  local existing
  existing="$(find "${BASE_DIR}/${PROVIDER_SLUG}" -maxdepth 1 -mindepth 1 -type d -name "${prefix}*" 2>/dev/null | sed -E "s|.*/${prefix}([0-9]+)$|\1|" | sort -n | tail -n 1 || true)"
  if [[ -z "${existing:-}" ]]; then
    echo "001"
  else
    printf '%03d' $((10#$existing + 1))
  fi
}

update_global_status() {
  local statuses=(
    "$CPU_STATUS"
    "$STORAGE_STATUS"
    "$NET_US_OUT_STATUS"
    "$NET_US_IN_STATUS"
    "$NET_EU_OUT_STATUS"
    "$NET_EU_IN_STATUS"
    "$NET_ASIA_OUT_STATUS"
    "$NET_ASIA_IN_STATUS"
  )

  GLOBAL_STATUS="ok"

  for s in "${statuses[@]}"; do
    case "$s" in
      failed_busy|failed_timeout|failed_connection|failed_incomplete|failed_error)
        if [[ "$GLOBAL_STATUS" != "error" ]]; then
          GLOBAL_STATUS="partial"
        fi
        ;;
      failed|parse_error|missing)
        GLOBAL_STATUS="error"
        return 0
        ;;
      ok|not_run)
        ;;
      *)
        GLOBAL_STATUS="error"
        return 0
        ;;
    esac
  done
}

cleanup_on_error() {
  local exit_code=$?
  stop_telemetry_sampler || true
  FINISHED_AT_UTC="$(timestamp_utc)"
  GLOBAL_STATUS="error"
  append_status_note "runner_exit_code=${exit_code}"
  log "Aborting with exit code ${exit_code}"
  if [[ -n "${RUN_DIR:-}" ]]; then
    write_run_md || true
    write_run_json || true
  fi
  exit "$exit_code"
}
trap cleanup_on_error ERR

parse_args() {
  RUNNER_ARGS=("$@")
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider)
        PROVIDER="${2:-}"
        shift 2
        ;;
      --region)
        REGION="${2:-}"
        shift 2
        ;;
      --plan)
        PLAN="${2:-}"
        shift 2
        ;;
      --price)
        PRICE="${2:-}"
        shift 2
        ;;
      --iperf-parallel)
        IPERF_PARALLEL="${2:-}"
        shift 2
        ;;
      --iperf-duration)
        IPERF_DURATION="${2:-}"
        shift 2
        ;;
      --measurement-epoch)
        MEASUREMENT_EPOCH="${2:-}"
        EPOCH="${MEASUREMENT_EPOCH}"
        shift 2
        ;;
      --agent-sim-enabled)
        AGENT_SIM_ENABLED="${2:-}"
        shift 2
        ;;
      --agent-sim-duration)
        AGENT_SIM_DURATION="${2:-}"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done

  [[ -n "$PROVIDER" ]] || die "--provider is required"
  [[ -n "$REGION" ]] || die "--region is required"
  [[ -n "$PLAN" ]] || die "--plan is required"
  [[ -n "$PRICE" ]] || die "--price is required"

  [[ "$IPERF_PARALLEL" =~ ^[0-9]+$ ]] || die "--iperf-parallel must be an integer"
  [[ "$IPERF_DURATION" =~ ^[0-9]+$ ]] || die "--iperf-duration must be an integer"
  [[ "$AGENT_SIM_ENABLED" =~ ^[01]$ ]] || die "--agent-sim-enabled must be 0 or 1"
  [[ "$AGENT_SIM_DURATION" =~ ^[0-9]+$ ]] || die "--agent-sim-duration must be an integer"
  validate_price || die "--price must be a non-negative number"
}

