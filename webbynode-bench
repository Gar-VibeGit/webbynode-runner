detect_environment() {
  CPU_MODEL="$(lscpu | awk -F: '/Model name/ {gsub(/^[ \t]+/, "", $2); print $2; exit}')"
  [[ -n "$CPU_MODEL" ]] || CPU_MODEL="$(awk -F: '/model name/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' /proc/cpuinfo 2>/dev/null || true)"
  [[ -n "$CPU_MODEL" ]] || CPU_MODEL="unknown"

  VCPU_COUNT="$(nproc 2>/dev/null || true)"
  [[ -n "$VCPU_COUNT" ]] || VCPU_COUNT="$(grep -c '^processor' /proc/cpuinfo 2>/dev/null || echo "1")"

  local mem_kb
  mem_kb="$(awk '/MemTotal/ {print $2; exit}' /proc/meminfo)"
  RAM_GB="$(to_float_gb "$mem_kb")"

  OS_NAME="$(detect_os_name)"
  KERNEL_VERSION="$(uname -r)"
  ARCH="$(uname -m)"
  HOSTNAME_FQDN="$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo "unknown")"
  VIRT_TYPE="$(detect_virtualization)"
  FIO_SIZE="$(compute_fio_size "$RAM_GB")"

  if [[ -z "$SYSBENCH_THREADS_OVERRIDE" ]]; then
    SYSBENCH_THREADS_OVERRIDE="$VCPU_COUNT"
  fi
}


start_telemetry_sampler() {
  : > "$TELEMETRY_LOG"
  if command -v mpstat >/dev/null 2>&1; then
    TELEMETRY_STATUS="ok"
    TELEMETRY_BACKEND="mpstat"
    (
      while true; do
        mpstat 1 1 2>/dev/null | awk '/Average:/ && $2 ~ /all/ {print strftime("%s"), $(NF), $(NF-4); fflush(); }' >> "$TELEMETRY_LOG"
      done
    ) &
    TELEMETRY_SAMPLER_PID=$!
    log "Telemetry sampler started with mpstat"
  else
    TELEMETRY_STATUS="not_available"
    TELEMETRY_BACKEND=""
    append_status_note "Telemetry not available: mpstat/sysstat not installed"
    log "mpstat not found; telemetry sampler disabled"
    TELEMETRY_SAMPLER_PID=""
  fi
}

stop_telemetry_sampler() {
  if [[ -n "${TELEMETRY_SAMPLER_PID:-}" ]]; then
    kill "$TELEMETRY_SAMPLER_PID" >/dev/null 2>&1 || true
    wait "$TELEMETRY_SAMPLER_PID" 2>/dev/null || true
    TELEMETRY_SAMPLER_PID=""
    log "Telemetry sampler stopped"
  fi
}

parse_telemetry_metrics() {
  if [[ ! -s "$TELEMETRY_LOG" ]]; then
    [[ "$TELEMETRY_STATUS" == "ok" ]] && TELEMETRY_STATUS="empty"
    return 0
  fi

  local parsed
  parsed="$(python3 - "$TELEMETRY_LOG" <<'PY'
import math, sys
from statistics import mean
path = sys.argv[1]
steal = []
iowait = []
with open(path, 'r', encoding='utf-8', errors='replace') as f:
    for line in f:
        parts = line.strip().split()
        if len(parts) < 3:
            continue
        try:
            steal.append(float(parts[1]))
            iowait.append(float(parts[2]))
        except Exception:
            pass
def pct(vals, q):
    if not vals:
        return ""
    vals = sorted(vals)
    idx = max(0, min(len(vals)-1, math.ceil(q * len(vals)) - 1))
    return vals[idx]
def fmt(v):
    return "" if v == "" else f"{v:.4f}"
time_above = 0.0
if steal:
    time_above = sum(1 for x in steal if x > 0.5) / len(steal) * 100.0
vals = [
    fmt(mean(steal)) if steal else "",
    fmt(pct(steal, 0.95)),
    fmt(max(steal)) if steal else "",
    fmt(time_above) if steal else "",
    fmt(mean(iowait)) if iowait else "",
    fmt(pct(iowait, 0.95)),
    fmt(max(iowait)) if iowait else "",
]
print("\t".join(vals))
PY
)"
  IFS=$'\t' read -r CPU_STEAL_AVG CPU_STEAL_P95 CPU_STEAL_MAX CPU_STEAL_TIME_ABOVE_05 IOWAIT_AVG IOWAIT_P95 IOWAIT_MAX <<< "$parsed"
}

parse_iperf_interval_metrics() {
  local path="$1"
  python3 - "$path" <<'PY'
import json, math, sys
path = sys.argv[1]
try:
    with open(path, 'r', encoding='utf-8', errors='replace') as f:
        j = json.load(f)
except Exception:
    print("\t\t\t")
    raise SystemExit(0)
values = []
for interval in j.get("intervals", []):
    streams = interval.get("streams", [])
    if streams:
        vals = [s.get("bits_per_second") for s in streams if s.get("bits_per_second") is not None]
        if vals:
            values.append(sum(vals))
            continue
    sums = interval.get("sum")
    if isinstance(sums, dict) and sums.get("bits_per_second") is not None:
        values.append(sums.get("bits_per_second"))
if not values:
    print("\t\t\t")
    raise SystemExit(0)
values = sorted(float(v) for v in values)
n = len(values)
def pct(q):
    idx = max(0, min(n-1, math.ceil(q*n)-1))
    return values[idx]
avg = sum(values)/n
std = (sum((v-avg)**2 for v in values)/n) ** 0.5
p50 = pct(0.50)
p95 = pct(0.95)
p99 = pct(0.99)
ratio = (p99 / p50) if p50 else None
def fmt(v):
    return "" if v is None else f"{v:.4f}"
print("\t".join([fmt(std), fmt(p95), fmt(p99), fmt(ratio)]))
PY
}

capture_iperf_variance_metrics() {
  local path="$1"
  local std_var="$2"
  local p95_var="$3"
  local p99_var="$4"
  local ratio_var="$5"
  local parsed
  parsed="$(parse_iperf_interval_metrics "$path")"
  IFS=$'\t' read -r _std _p95 _p99 _ratio <<< "$parsed"
  printf -v "$std_var" '%s' "${_std:-}"
  printf -v "$p95_var" '%s' "${_p95:-}"
  printf -v "$p99_var" '%s' "${_p99:-}"
  printf -v "$ratio_var" '%s' "${_ratio:-}"
}

run_agent_sim() {
  if [[ "$AGENT_SIM_ENABLED" != "1" ]]; then
    log "Agent simulation disabled"
    return 0
  fi

  log "Running agent simulation v1"
  python3 - "$AGENT_SIM_JSON" "$RAW_AGENT_SIM_LOG" "$AGENT_SIM_DURATION" "$US_ENDPOINT" "$RUN_DIR/agent.db" "$RUN_DIR/agent.log" "$AGENT_SIM_WINDOW_PERCENT" <<'PY'
import hashlib, json, math, os, sqlite3, statistics, sys, time, urllib.request
out_json, out_log, duration_s, endpoint, db_path, log_path, window_pct = sys.argv[1:]
duration_s = int(duration_s)
window_pct = int(window_pct)
start = time.time()
deadline = start + duration_s
iterations = 0
successful = 0
failed = 0
latencies = []
successful_latencies = []
disk_write_failures = 0
disk_checksum_failures = 0
conn = sqlite3.connect(db_path)
cur = conn.cursor()
cur.execute("CREATE TABLE IF NOT EXISTS kv (id INTEGER PRIMARY KEY, payload TEXT)")
if cur.execute("SELECT COUNT(*) FROM kv").fetchone()[0] == 0:
    cur.executemany("INSERT INTO kv (payload) VALUES (?)", [(f'payload-{i}',) for i in range(1000)])
    conn.commit()
with open(out_log, "w", encoding="utf-8") as raw:
    while time.time() < deadline:
        iter_started_at = time.time()
        ok = True
        error_type = None
        error_message = None
        try:
            ids = [((iterations * 17 + i * 13) % 1000) + 1 for i in range(25)]
            for row_id in ids:
                cur.execute("SELECT payload FROM kv WHERE id=?", (row_id,))
                cur.fetchone()
            blob = (f"agent-iter-{iterations}-" + "x"*1024).encode()
            for _ in range(5000):
                hashlib.sha256(blob).hexdigest()
            req = urllib.request.Request(f"http://{endpoint}/ping", headers={"User-Agent": "webbynode-agent-sim/1.0"})
            with urllib.request.urlopen(req, timeout=2) as resp:
                status_code = getattr(resp, "status", 200)
                resp.read(10240)
                if status_code != 200:
                    ok = False
                    error_type = "HTTPStatus"
                    error_message = f"status={status_code}"
            checksum = hashlib.sha256(f"{time.time()}-{iterations}".encode()).hexdigest()
            try:
                with open(log_path, "a", encoding="utf-8") as lf:
                    lf.write(checksum + "\n")
                    lf.flush()
