#!/usr/bin/env bash
set -Eeuo pipefail

BASE_DIR="/benchmarks"

US_ENDPOINT_HOST="66.135.13.218"
EU_ENDPOINT_HOST="46.225.222.50"

US_TARGET_SLUG="us-east-iperf"
EU_TARGET_SLUG="eu-west-iperf"

IPERF_PORT="5201"
IPERF_DURATION="${IPERF_DURATION:-15}"
IPERF_PARALLEL="${IPERF_PARALLEL:-1}"

FIO_RUNTIME="30"
FIO_SIZE="1G"

usage() {
  cat <<EOF
Usage:
  $0 --provider <provider> --region <region> --plan <plan> --price <price>
EOF
  exit 1
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

slugify() {
  local s="${1,,}"
  s="$(echo "$s" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  printf '%s' "$s"
}

log() {
  echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] $*" | tee -a "$RUN_LOG"
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

detect_os_name() {
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "${PRETTY_NAME:-${NAME:-unknown}}"
  else
    uname -s
  fi
}

detect_virtualization() {
  if command -v systemd-detect-virt >/dev/null 2>&1; then
    systemd-detect-virt 2>/dev/null || echo "unknown"
  else
    echo "unknown"
  fi
}

parse_args() {
  PROVIDER=""
  REGION=""
  PLAN=""
  PRICE=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider)
        PROVIDER="${2:-}"
        shift 2
        ;;
      --region)
        REGION="${2:-}"
        shift 2
        ;;
      --plan)
        PLAN="${2:-}"
        shift 2
        ;;
      --price)
        PRICE="${2:-}"
        shift 2
        ;;
      -h|--help)
        usage
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done

  [[ -n "$PROVIDER" ]] || usage
  [[ -n "$REGION" ]] || usage
  [[ -n "$PLAN" ]] || usage
  [[ -n "$PRICE" ]] || usage
}

validate_inputs() {
  [[ "$IPERF_PARALLEL" =~ ^[0-9]+$ ]] || die "IPERF_PARALLEL must be an integer"
  [[ "$IPERF_DURATION" =~ ^[0-9]+$ ]] || die "IPERF_DURATION must be an integer"

  python3 - <<'PY' "$PRICE" || die "--price must be a non-negative number"
import sys
v = float(sys.argv[1])
assert v >= 0
PY
}

check_dependencies() {
  require_cmd python3
  require_cmd awk
  require_cmd sed
  require_cmd grep
  require_cmd date
  require_cmd uname
  require_cmd free
  require_cmd hostname
  require_cmd lscpu
  require_cmd nproc
  require_cmd sysbench
  require_cmd fio
  require_cmd iperf3
}

init_run() {
  PROVIDER_SLUG="$(slugify "$PROVIDER")"
  REGION_SLUG="$(slugify "$REGION")"
  PLAN_SLUG="$(slugify "$PLAN")"
  RUN_DATE="$(date -u +"%Y-%m-%d")"

  mkdir -p "$BASE_DIR/$PROVIDER_SLUG"

  local prefix="${PROVIDER_SLUG}-${REGION_SLUG}-${PLAN_SLUG}-${RUN_DATE}-"
  local last_seq
  last_seq="$(
    find "$BASE_DIR/$PROVIDER_SLUG" -maxdepth 1 -mindepth 1 -type d -name "${prefix}[0-9][0-9][0-9]" 2>/dev/null \
      | sed -nE "s|.*/${prefix}([0-9]{3})$|\1|p" \
      | sort \
      | tail -n 1
  )"

  if [[ -z "${last_seq:-}" ]]; then
    RUN_SEQ="001"
  else
    RUN_SEQ="$(printf '%03d' $((10#$last_seq + 1)))"
  fi

  RUN_ID="${PROVIDER_SLUG}-${REGION_SLUG}-${PLAN_SLUG}-${RUN_DATE}-${RUN_SEQ}"
  RUN_DIR="$BASE_DIR/$PROVIDER_SLUG/$RUN_ID"

  mkdir -p "$RUN_DIR"

  RUN_LOG="$RUN_DIR/run.log"
  RAW_SYSBENCH_LOG="$RUN_DIR/raw.sysbench.log"
  RAW_FIO_LOG="$RUN_DIR/raw.fio.log"
  RAW_IPERF_US_OUT_LOG="$RUN_DIR/raw.iperf-us-east-outbound.log"
  RAW_IPERF_US_IN_LOG="$RUN_DIR/raw.iperf-us-east-inbound.log"
  RAW_IPERF_EU_OUT_LOG="$RUN_DIR/raw.iperf-eu-west-outbound.log"
  RAW_IPERF_EU_IN_LOG="$RUN_DIR/raw.iperf-eu-west-inbound.log"
  RUN_JSON="$RUN_DIR/run.json"
  RUN_MD="$RUN_DIR/run.md"

  TESTED_AT_UTC="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  log "Starting benchmark $RUN_ID"
}

detect_environment() {
  CPU_MODEL="$(lscpu | awk -F: '/Model name/ {gsub(/^[ \t]+/, "", $2); print $2; exit}')"
  [[ -n "$CPU_MODEL" ]] || CPU_MODEL="unknown"

  VCPU_COUNT="$(nproc --all 2>/dev/null || echo 1)"

  RAM_GB="$(
    python3 - <<'PY'
import re
mem_kb = 0
with open('/proc/meminfo', 'r', encoding='utf-8') as f:
    for line in f:
        if line.startswith('MemTotal:'):
            mem_kb = int(re.findall(r'\d+', line)[0])
            break
print(f"{mem_kb / 1024 / 1024:.2f}")
PY
  )"

  OS_NAME="$(detect_os_name)"
  KERNEL_VERSION="$(uname -r)"
  ARCH="$(uname -m)"
  HOSTNAME_FQDN="$(hostname -f 2>/dev/null || hostname)"
  VIRT_TYPE="$(detect_virtualization)"
}

run_cpu() {
  log "Running CPU benchmark"

  CPU_CMD="sysbench cpu --threads=${VCPU_COUNT} --time=30 --cpu-max-prime=20000 run"
  echo "$CPU_CMD" > "$RUN_DIR/cmd.sysbench.txt"
  eval "$CPU_CMD" > "$RAW_SYSBENCH_LOG" 2>&1

  CPU_EVENTS_PER_SECOND="$(awk '/events per second:/ {print $4; exit}' "$RAW_SYSBENCH_LOG")"
  CPU_LAT_AVG="$(awk '/avg:/ {print $2; exit}' "$RAW_SYSBENCH_LOG")"
  CPU_LAT_P95="$(awk '/95th percentile:/ {print $3; exit}' "$RAW_SYSBENCH_LOG")"

  [[ -n "${CPU_EVENTS_PER_SECOND:-}" ]] || die "Failed to parse CPU events_per_second"
  [[ -n "${CPU_LAT_AVG:-}" ]] || CPU_LAT_AVG="null"
  [[ -n "${CPU_LAT_P95:-}" ]] || CPU_LAT_P95="null"
}

run_storage() {
  log "Running storage benchmark"

  FIO_CMD="fio --name=webbynode-storage --filename=$RUN_DIR/fio.test --size=$FIO_SIZE --rw=randrw --rwmixread=50 --bs=4k --ioengine=libaio --direct=1 --iodepth=64 --numjobs=1 --time_based=1 --runtime=$FIO_RUNTIME --group_reporting=1 --output-format=json"
  echo "$FIO_CMD" > "$RUN_DIR/cmd.fio.txt"
  eval "$FIO_CMD" > "$RAW_FIO_LOG" 2>&1

  read -r FIO_READ_IOPS FIO_WRITE_IOPS FIO_VERSION FIO_READ_P95 FIO_READ_P99 FIO_WRITE_P95 FIO_WRITE_P99 <<EOF
$(
python3 - <<'PY' "$RAW_FIO_LOG"
import json, sys
with open(sys.argv[1], 'r', encoding='utf-8') as f:
    j = json.load(f)
job = j["jobs"][0]
fio_version = j.get("fio version", "")
read_iops = job["read"]["iops"]
write_iops = job["write"]["iops"]
read_p95 = job["read"].get("clat_ns", {}).get("percentile", {}).get("95.000000")
read_p99 = job["read"].get("clat_ns", {}).get("percentile", {}).get("99.000000")
write_p95 = job["write"].get("clat_ns", {}).get("percentile", {}).get("95.000000")
write_p99 = job["write"].get("clat_ns", {}).get("percentile", {}).get("99.000000")
print(read_iops, write_iops, fio_version, read_p95, read_p99, write_p95, write_p99)
PY
)
EOF

  rm -f "$RUN_DIR/fio.test" 2>/dev/null || true
}

run_iperf_json() {
  local host="$1"
  local outfile="$2"
  local reverse_flag="${3:-}"

  if [[ "$reverse_flag" == "reverse" ]]; then
    iperf3 -c "$host" -p "$IPERF_PORT" -P "$IPERF_PARALLEL" -t "$IPERF_DURATION" -J -R > "$outfile" 2>&1
  else
    iperf3 -c "$host" -p "$IPERF_PORT" -P "$IPERF_PARALLEL" -t "$IPERF_DURATION" -J > "$outfile" 2>&1
  fi
}

parse_iperf_json() {
  local infile="$1"

  python3 - <<'PY' "$infile"
import json, sys
path = sys.argv[1]
try:
    with open(path, 'r', encoding='utf-8') as f:
        j = json.load(f)
    end = j.get("end", {})
    connected = j.get("start", {}).get("connected", [])
    remote_host = connected[0].get("remote_host") if connected else ""
    sum_sent = end.get("sum_sent", {})
    sum_received = end.get("sum_received", {})
    sent_bps = sum_sent.get("bits_per_second")
    recv_bps = sum_received.get("bits_per_second")
    if sent_bps is None or recv_bps is None:
        raise ValueError("missing throughput fields")
    print(remote_host, sent_bps, recv_bps)
except Exception:
    print("PARSE_ERROR")
PY
}

run_network() {
  log "Running US outbound network benchmark"
  run_iperf_json "$US_ENDPOINT_HOST" "$RAW_IPERF_US_OUT_LOG"

  log "Running US inbound network benchmark"
  run_iperf_json "$US_ENDPOINT_HOST" "$RAW_IPERF_US_IN_LOG" reverse

  log "Running EU outbound network benchmark"
  run_iperf_json "$EU_ENDPOINT_HOST" "$RAW_IPERF_EU_OUT_LOG"

  log "Running EU inbound network benchmark"
  run_iperf_json "$EU_ENDPOINT_HOST" "$RAW_IPERF_EU_IN_LOG" reverse

  local parsed

  parsed="$(parse_iperf_json "$RAW_IPERF_US_OUT_LOG")"
  [[ "$parsed" != "PARSE_ERROR" ]] || die "Failed to parse US outbound iperf JSON"
  read -r US_OUT_REMOTE_HOST US_OUT_SENT_BPS US_OUT_RECEIVED_BPS <<< "$parsed"

  parsed="$(parse_iperf_json "$RAW_IPERF_US_IN_LOG")"
  [[ "$parsed" != "PARSE_ERROR" ]] || die "Failed to parse US inbound iperf JSON"
  read -r US_IN_REMOTE_HOST US_IN_SENT_BPS US_IN_RECEIVED_BPS <<< "$parsed"

  parsed="$(parse_iperf_json "$RAW_IPERF_EU_OUT_LOG")"
  [[ "$parsed" != "PARSE_ERROR" ]] || die "Failed to parse EU outbound iperf JSON"
  read -r EU_OUT_REMOTE_HOST EU_OUT_SENT_BPS EU_OUT_RECEIVED_BPS <<< "$parsed"

  parsed="$(parse_iperf_json "$RAW_IPERF_EU_IN_LOG")"
  [[ "$parsed" != "PARSE_ERROR" ]] || die "Failed to parse EU inbound iperf JSON"
  read -r EU_IN_REMOTE_HOST EU_IN_SENT_BPS EU_IN_RECEIVED_BPS <<< "$parsed"
}

ns_to_ms_expr() {
  python3 - <<'PY' "$1"
import sys
v = sys.argv[1]
if v in ("None", "", "null"):
    print("null")
else:
    print(float(v) / 1_000_000)
PY
}

bps_to_gbps_expr() {
  python3 - <<'PY' "$1"
import sys
print(float(sys.argv[1]) / 1_000_000_000)
PY
}

write_run_md() {
  cat > "$RUN_MD" <<EOF
# $RUN_ID

- Provider: $PROVIDER
- Region: $REGION
- Plan: $PLAN
- Price: $PRICE
- Tested at: $TESTED_AT_UTC

## Environment
- CPU: $CPU_MODEL
- vCPU: $VCPU_COUNT
- RAM (GB): $RAM_GB
- OS: $OS_NAME
- Kernel: $KERNEL_VERSION

## CPU
- Events/s: $CPU_EVENTS_PER_SECOND

## Storage
- Read IOPS: $FIO_READ_IOPS
- Write IOPS: $FIO_WRITE_IOPS

## Network
- US outbound Gbps: $(bps_to_gbps_expr "$US_OUT_RECEIVED_BPS")
- US inbound Gbps: $(bps_to_gbps_expr "$US_IN_RECEIVED_BPS")
- EU outbound Gbps: $(bps_to_gbps_expr "$EU_OUT_RECEIVED_BPS")
- EU inbound Gbps: $(bps_to_gbps_expr "$EU_IN_RECEIVED_BPS")
EOF
}

